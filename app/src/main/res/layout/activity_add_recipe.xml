<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/cancelButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:tint="@color/text_secondary"
                android:contentDescription="Назад"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Новий рецепт"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="НАЗВА"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="6dp" />
                <EditText
                    android:id="@+id/nameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:hint="Введіть назву"
                    android:textColorHint="@color/text_placeholder"
                    android:inputType="textCapSentences"
                    android:maxLines="2"
                    android:background="@null"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Ingredients -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ІНГРЕДІЄНТИ"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="6dp" />
                <EditText
                    android:id="@+id/ingredientsEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:hint="Кожен інгредієнт з нового рядка"
                    android:textColorHint="@color/text_placeholder"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:gravity="top"
                    android:background="@null"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Difficulty -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СКЛАДНІСТЬ"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="6dp" />
                <RadioGroup
                    android:id="@+id/difficultyRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <RadioButton
                        android:id="@+id/easyRadioButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Легкий"
                        android:textColor="@color/difficulty_easy"
                        android:textSize="13sp"
                        android:buttonTint="@color/difficulty_easy"
                        android:gravity="center_vertical"
                        android:checked="true" />
                    <RadioButton
                        android:id="@+id/mediumRadioButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Середній"
                        android:textColor="@color/difficulty_medium"
                        android:textSize="13sp"
                        android:buttonTint="@color/difficulty_medium"
                        android:gravity="center_vertical" />
                    <RadioButton
                        android:id="@+id/hardRadioButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Складний"
                        android:textColor="@color/difficulty_hard"
                        android:textSize="13sp"
                        android:buttonTint="@color/difficulty_hard"
                        android:gravity="center_vertical" />
                </RadioGroup>
            </LinearLayout>

            <!-- Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ЧАС (ХВ)"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="6dp" />
                <EditText
                    android:id="@+id/timeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:hint="60"
                    android:textColorHint="@color/text_placeholder"
                    android:inputType="number"
                    android:background="@null"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Instructions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ІНСТРУКЦІЇ"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="6dp" />
                <EditText
                    android:id="@+id/instructionsEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:hint="Опишіть процес приготування"
                    android:textColorHint="@color/text_placeholder"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="4"
                    android:gravity="top"
                    android:background="@null"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Calculate КБЖВ -->
            <Button
                android:id="@+id/calculateNutritionButton"
                style="@style/SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Розрахувати КБЖВ" />

            <!-- КБЖВ section -->
            <LinearLayout
                android:id="@+id/kbzuSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="КБЖВ"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp">
                        <EditText
                            android:id="@+id/caloriesEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:hint="—"
                            android:textColorHint="@color/text_placeholder"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:gravity="center"
                            android:padding="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ккал"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp">
                        <EditText
                            android:id="@+id/proteinsEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#4CAF50"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:hint="—"
                            android:textColorHint="@color/text_placeholder"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:gravity="center"
                            android:padding="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="білки"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp">
                        <EditText
                            android:id="@+id/fatsEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FF9800"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:hint="—"
                            android:textColorHint="@color/text_placeholder"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:gravity="center"
                            android:padding="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="жири"
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp">
                        <EditText
                            android:id="@+id/carbsEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#2196F3"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:hint="—"
                            android:textColorHint="@color/text_placeholder"
                            android:inputType="numberDecimal"
                            android:background="@null"
                            android:gravity="center"
                            android:padding="0dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="вугл."
                            android:textColor="@color/text_muted"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Save button at the bottom -->
            <Button
                android:id="@+id/saveButton"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Зберегти рецепт" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>