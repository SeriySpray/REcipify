<?xml version="1.0" encoding="utf-8"?>
<!-- Meal detail — design-screens-v3 (flat, monochromatic) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBackLink"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/icon_btn_bg"
            android:src="@drawable/ic_arrow_back"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:tint="@color/text_secondary"
            android:contentDescription="Назад"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Деталі страви"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Food name -->
            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Назва страви"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="2dp" />

            <!-- Meal date -->
            <TextView
                android:id="@+id/tvMealDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 жовтня 2024, 14:30"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <!-- КБЖВ pills -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_field_bg"
                    android:padding="8dp"
                    android:gravity="center"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:id="@+id/tvCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ккал"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_field_bg"
                    android:padding="8dp"
                    android:gravity="center"
                    android:layout_marginHorizontal="2dp">
                    <TextView
                        android:id="@+id/tvProteins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0г"
                        android:textColor="#4CAF50"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="білки"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_field_bg"
                    android:padding="8dp"
                    android:gravity="center"
                    android:layout_marginHorizontal="2dp">
                    <TextView
                        android:id="@+id/tvFats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0г"
                        android:textColor="#FF9800"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="жири"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_field_bg"
                    android:padding="8dp"
                    android:gravity="center"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:id="@+id/tvCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0г"
                        android:textColor="#2196F3"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="вугл."
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Macro Distribution Chart -->
            <LinearLayout
                android:id="@+id/chartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="РОЗПОДІЛ НУТРІЄНТІВ"
                    style="@style/FieldLabel"
                    android:layout_marginBottom="4dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/macrosPieChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />

                <!-- Custom centered legend (replaces built-in unreliable MPAndroidChart legend) -->
                <LinearLayout
                    android:id="@+id/customLegend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginHorizontal="10dp">
                        <View
                            android:id="@+id/legendDotProtein"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_indicator"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:id="@+id/tvLegendProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Білки 0%"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginHorizontal="10dp">
                        <View
                            android:id="@+id/legendDotFat"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_indicator"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:id="@+id/tvLegendFat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Жири 0%"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginHorizontal="10dp">
                        <View
                            android:id="@+id/legendDotCarbs"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/dot_indicator"
                            android:layout_marginEnd="6dp" />
                        <TextView
                            android:id="@+id/tvLegendCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Вугл. 0%"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="horizontal"
                android:padding="14dp"
                android:layout_marginBottom="8dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ПРОДУКТІВ"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/tvProductCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#222"
                    android:layout_marginHorizontal="16dp"
                    android:layout_gravity="center_vertical" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ЗАГАЛЬНА ВАГА"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp" />
                    <TextView
                        android:id="@+id/tvTotalWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0г"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Contribution to Goal -->
            <LinearLayout
                android:id="@+id/contributionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ВНЕСОК У ДЕННУ ЦІЛЬ"
                        android:textColor="@color/text_muted"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tvContributionPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/goalProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/white"
                    android:progressBackgroundTint="#222222" />
            </LinearLayout>

            <!-- Products section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СКЛАД СТРАВИ"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/productsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_field_bg"
                android:padding="10dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Hidden toolbar stub for binding compatibility -->
    <View android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>