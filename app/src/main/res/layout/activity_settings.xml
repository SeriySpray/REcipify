<?xml version="1.0" encoding="utf-8"?>
<!-- Налаштування — design-screens-v3 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBackLink"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:tint="@color/text_secondary"
                android:contentDescription="Назад"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Налаштування"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <!-- Section: Енергетична ціль -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ЕНЕРГЕТИЧНА ЦІЛЬ"
            style="@style/SectionLabel"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Встановіть вашу цільову норму калорій на день."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Calories field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КАЛОРІЇ"
                style="@style/FieldLabel"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etTargetCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="2000 ккал"
                android:textColorHint="@color/text_placeholder"
                android:inputType="number"
                android:background="@null"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Section: Нутрієнти -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="НУТРІЄНТИ"
            style="@style/SectionLabel"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Точні цілі для білків, жирів та вуглеводів допоможуть краще збалансувати ваш раціон."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Proteins field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="БІЛКИ"
                style="@style/FieldLabel"
                android:textColor="#4CAF50"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etTargetProteins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="150 г"
                android:textColorHint="@color/text_placeholder"
                android:inputType="number"
                android:background="@null"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Fats field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЖИРИ"
                style="@style/FieldLabel"
                android:textColor="#FF9800"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etTargetFats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="65 г"
                android:textColorHint="@color/text_placeholder"
                android:inputType="number"
                android:background="@null"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Carbs field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ВУГЛЕВОДИ"
                style="@style/FieldLabel"
                android:textColor="#2196F3"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/etTargetCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="250 г"
                android:textColorHint="@color/text_placeholder"
                android:inputType="number"
                android:background="@null"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Section: Тема -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ТЕМА"
            style="@style/SectionLabel"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Оберіть тему інтерфейсу."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="horizontal"
            android:padding="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnThemeDark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Темна"
                android:gravity="center"
                android:padding="10dp"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnThemeLight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Світла"
                android:gravity="center"
                android:padding="10dp"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveSettings"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зберегти" />

        <!-- Hidden toolbar for code compat -->
        <View android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
