<?xml version="1.0" encoding="utf-8"?>
<!-- Дашборд — design-screens-v3 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сьогодні"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/dateTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Calories progress card -->
        <LinearLayout
            android:id="@+id/caloriesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_field_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="КАЛОРІЇ"
                    style="@style/FieldLabel" />

                <TextView
                    android:id="@+id/caloriesTodayTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Custom progress bar -->
            <FrameLayout
                android:id="@+id/progressBarContainer"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginBottom="14dp">
                <View
                    android:id="@+id/progressFill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <TextView
                android:id="@+id/caloriesGoalTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Macros progress pill -->
        <LinearLayout
            android:id="@+id/macrosCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/kbzu_pill_bg"
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <!-- Proteins -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/proteinsCircular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:max="100"
                        app:indicatorColor="#4CAF50"
                        app:trackColor="#1A1A1A"
                        app:indicatorSize="48dp"
                        app:trackThickness="4dp" />

                    <TextView
                        android:id="@+id/proteinsTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="БІЛКИ"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/proteinsGoalTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Fats -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/fatsCircular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:max="100"
                        app:indicatorColor="#FF9800"
                        app:trackColor="#1A1A1A"
                        app:indicatorSize="48dp"
                        app:trackThickness="4dp" />

                    <TextView
                        android:id="@+id/fatsTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ЖИРИ"
                    android:textColor="#FF9800"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/fatsGoalTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Carbs -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/carbsCircular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:max="100"
                        app:indicatorColor="#2196F3"
                        app:trackColor="#1A1A1A"
                        app:indicatorSize="48dp"
                        app:trackThickness="4dp" />

                    <TextView
                        android:id="@+id/carbsTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ВУГЛЕВОДИ"
                    android:textColor="#2196F3"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/carbsGoalTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Streak badge -->
        <LinearLayout
            android:id="@+id/streakCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/streak_label"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/streakTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/streak_badge_bg"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>



    </LinearLayout>
</ScrollView>
