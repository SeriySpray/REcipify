<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black">

    <!-- Date Navigation with Streak -->
    <LinearLayout
        android:id="@+id/dateNavContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/btnPrevDay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="&lt;"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dateTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                tools:text="Сьогодні" />

            <!-- Compact Streak Badge next to date -->
            <LinearLayout
                android:id="@+id/streakContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/streak_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_fire"
                    android:tint="@color/text_tertiary"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/streakTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold"
                    tools:text="5" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btnNextDay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="&gt;"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="100dp">

            <!-- Calories card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="bottom">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="КАЛОРІЇ"
                        style="@style/FieldLabel"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/caloriesTodayTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-bold"
                        tools:text="1200" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ккал"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="2dp"
                        android:layout_marginBottom="2dp" />
                </LinearLayout>

                <!-- Progress bar -->
                <FrameLayout
                    android:id="@+id/progressBarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginBottom="10dp">
                    <View
                        android:id="@+id/progressFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/caloriesGoalTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="з 2000 ккал" />
            </LinearLayout>

            <!-- Macros progress pill -->
            <LinearLayout
                android:id="@+id/macrosCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/kbzu_pill_bg"
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Proteins -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/proteinsCircular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:max="100"
                            app:indicatorColor="#4CAF50"
                            app:trackColor="@color/surface_elevated"
                            app:indicatorSize="48dp"
                            app:trackThickness="4dp" />

                        <TextView
                            android:id="@+id/proteinsTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            tools:text="45" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="БІЛКИ"
                        android:textColor="#4CAF50"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:id="@+id/proteinsGoalTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        tools:text="з 150г" />
                </LinearLayout>

                <!-- Fats -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/fatsCircular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:max="100"
                            app:indicatorColor="#FF9800"
                            app:trackColor="@color/surface_elevated"
                            app:indicatorSize="48dp"
                            app:trackThickness="4dp" />

                        <TextView
                            android:id="@+id/fatsTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            tools:text="32" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ЖИРИ"
                        android:textColor="#FF9800"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:id="@+id/fatsGoalTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        tools:text="з 65г" />
                </LinearLayout>

                <!-- Carbs -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/carbsCircular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:max="100"
                            app:indicatorColor="#2196F3"
                            app:trackColor="@color/surface_elevated"
                            app:indicatorSize="48dp"
                            app:trackThickness="4dp" />

                        <TextView
                            android:id="@+id/carbsTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            tools:text="180" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ВУГЛЕВОДИ"
                        android:textColor="#2196F3"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:id="@+id/carbsGoalTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        tools:text="з 250г" />
                </LinearLayout>
            </LinearLayout>

            <!-- Meals List -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПРИЙОМИ ЇЖІ"
                style="@style/FieldLabel"
                android:layout_marginBottom="8dp"
                android:textSize="11sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMeals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_saved_meal" />

            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Немає записів за цей день"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingVertical="32dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Pinned Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="20dp"
        android:paddingTop="12dp"
        android:background="@drawable/bottom_fade_gradient">

        <Button
            android:id="@+id/btnManualAdd"
            style="@style/SecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Додати вручну"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@color/surface_elevated"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnAnalyze"
            style="@style/PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Аналіз страви"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
