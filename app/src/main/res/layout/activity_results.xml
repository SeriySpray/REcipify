<?xml version="1.0" encoding="utf-8"?>
<!-- Результат аналізу — design-screens-v3 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBackLink"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:tint="@color/text_secondary"
                android:contentDescription="Назад"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Результат аналізу"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Result header card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_field_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvFoodName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"
                    tools:text="Борщ" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="СКЛАД СТРАВИ"
                    style="@style/SectionLabel"
                    android:layout_marginBottom="8dp" />

                <!-- Products container (inline ingredient listing) -->
                <LinearLayout
                    android:id="@+id/productsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="10dp" />

                <!-- КБЖВ pills -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">
                        <TextView
                            android:id="@+id/tvCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            tools:text="320" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ккал"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">
                        <TextView
                            android:id="@+id/tvProteins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/chart_protein"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            tools:text="18г" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="білки"
                            android:textColor="@color/chart_protein"
                            android:textSize="10sp"
                            android:alpha="0.8" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">
                        <TextView
                            android:id="@+id/tvFats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/chart_fat"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            tools:text="8г" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="жири"
                            android:textColor="@color/chart_fat"
                            android:textSize="10sp"
                            android:alpha="0.8" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/kbzu_pill_bg"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="6dp">
                        <TextView
                            android:id="@+id/tvCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/chart_carbs"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            tools:text="42г" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="вугл."
                            android:textColor="@color/chart_carbs"
                            android:textSize="10sp"
                            android:alpha="0.8" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="8dp" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSave"
                    style="@style/PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Зберегти прийом" />

                <Button
                    android:id="@+id/btnClose"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Hidden toolbar for code compat -->
            <View android:id="@+id/toolbar"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>